#GH_TOKEN=github_pat_xxxxxxxxxxxx
#GIT_USER_NAME=John Doe
#GIT_USER_EMAIL=john.doe@email.de

# AI-provider API keys. These are also forwarded automatically from your host
# environment when set (see "passthroughEnv" in claude-task.json); set them
# here only if you prefer keeping them in this git-ignored file.
#OPENAI_API_KEY=sk-xxxxxxxxxxxx
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Local override for the claude-task container/image name. Wins over the
# committed "name" in .devcontainer/claude-task.json; unset (or empty) falls
# back to that config value, then to the repository directory name.
#CLAUDE_TASK_NAME=my-project
