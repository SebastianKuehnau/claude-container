# Environment für .devcontainer
# Kopieren Sie diese Datei als .env im .devcontainer Verzeichnis
# ODER setzen Sie die Variablen in Ihrer Shell

# === Projekt-Konfiguration ===
PROJECT_NAME=my-project

# === Timezone ===
TZ=Europe/Berlin

# === Java Konfiguration ===
JAVA_VERSION=25
JAVA_VENDOR=temurin

# === Firewall ===
SKIP_FIREWALL=1

# === Git Konfiguration (optional) ===
# GIT_USER_NAME=Ihr Name
# GIT_USER_EMAIL=ihre.email@example.com

# === Vaadin Pro Key (optional) ===
# VAADIN_PRO_KEY=pro-xxxx

# === GitHub Token (optional) ===
# GH_TOKEN=ghp_xxxx